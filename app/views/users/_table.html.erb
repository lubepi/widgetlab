<div class="table-responsive">
  <table class="table table-hover">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Sub</th>
        <th class="text-end">Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% if users.any? %>
        <% users.each do |user| %>
          <tr>
            <td><strong><%= [user.first_name, user.last_name].compact.join(" ") %></strong></td>
            <td><%= user.email %></td>
            <td><%= user.sub %></td>
            <td class="text-end">
              <div class="btn-group" role="group">
                <%= link_to user_path(user),
                    class: "btn btn-sm btn-outline-primary",
                    title: "Details anzeigen",
                    data: {
                      turbo_frame: "modal",
                      turbo_method: :get
                    } do %>
                  <i class="bi bi-eye"></i>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="4" class="text-center text-muted py-4">
            Keine Benutzer vorhanden.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
