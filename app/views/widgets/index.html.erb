<% content_for :title, "Widget Store" %>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">
      <i class="bi bi-grid me-2"></i>
      Widget Store
    </h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newWidgetModal">
      <i class="bi bi-plus-circle"></i> Widget erstellen
    </button>
  </div>

  <div id="widgets_list">
    <%= render "index_content" %>
  </div>
</div>

<%= render "modal" %>

<turbo-frame id="widget_modal"></turbo-frame>
