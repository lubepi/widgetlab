<% content_for :title, "Widget Shop" %>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Widget Shop</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newWidgetModal">
      <i class="bi bi-plus-circle"></i> Widget erstellen
    </button>
  </div>

  <%= turbo_frame_tag "widgets_grid" do %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="widgets">
      <% @widgets.each do |widget| %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
              <%= render widget %>
            </div>
            <div class="card-body">
              <h5 class="card-title"><%= widget.name %></h5>
              <%= link_to "Details", widget_path(widget), 
                  class: "btn btn-sm btn-outline-primary",
                  data: { turbo_frame: "widget_modal" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%= turbo_frame_tag "widget_modal" do %>
  <%= render "modal" %>
<% end %>
