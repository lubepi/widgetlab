<% if @owned_widgets.empty? && @shared_widgets.empty? && @public_widgets.empty? %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-grid display-1 text-muted mb-3"></i>
      <h4 class="text-muted">Noch keine Widgets vorhanden</h4>
      <p class="text-muted mb-4">Erstelle dein erstes Widget, um loszulegen.</p>
      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newWidgetModal">
        <i class="bi bi-plus-circle"></i> Widget erstellen
      </button>
    </div>
  </div>
<% else %>
  <%# Meine Widgets (Owner) %>
  <% unless @owned_widgets.empty? %>
    <h5 class="mb-3">
      <i class="bi bi-person-fill me-2"></i>
      Meine Widgets
    </h5>
    <%= render "widgets/widgets_grid", widgets: @owned_widgets %>
    <div class="mb-5"></div>
  <% end %>

  <%# Mit mir geteilt %>
  <% unless @shared_widgets.empty? %>
    <h5 class="mb-3">
      <i class="bi bi-people-fill me-2"></i>
      Mit mir geteilt
    </h5>
    <%= render "widgets/widgets_grid", widgets: @shared_widgets %>
    <div class="mb-5"></div>
  <% end %>

  <%# Öffentliche Widgets %>
  <% unless @public_widgets.empty? %>
    <h5 class="mb-3">
      <i class="bi bi-globe me-2"></i>
      Öffentliche Widgets
    </h5>
    <%= render "widgets/widgets_grid", widgets: @public_widgets %>
  <% end %>
<% end %>
