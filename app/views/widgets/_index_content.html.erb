<% if @owned_widgets.empty? && @shared_widgets.empty? && @public_widgets.empty? %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="bi bi-grid display-1 text-muted mb-3"></i>
      <h4 class="text-muted"><%= t('widgets.index.empty_state.title') %></h4>
      <p class="text-muted mb-4"><%= t('widgets.index.empty_state.description') %></p>
      <%= link_to new_widget_path, data: { turbo_frame: "widget_modal" }, class: "btn btn-primary" do %>
        <i class="bi bi-plus-circle"></i> <%= t('widgets.index.empty_state.button') %>
      <% end %>
    </div>
  </div>
<% else %>
  <%# Meine Widgets (Owner) %>
  <% unless @owned_widgets.empty? %>
    <h5 class="mb-3">
      <i class="bi bi-person-fill me-2"></i>
      <%= t('widgets.index.sections.my_widgets') %>
    </h5>
    <%= render "widgets/widgets_grid", widgets: @owned_widgets %>
    <div class="mb-5"></div>
  <% end %>

  <%# Mit mir geteilt %>
  <% unless @shared_widgets.empty? %>
    <h5 class="mb-3">
      <i class="bi bi-people-fill me-2"></i>
      <%= t('widgets.index.sections.shared_with_me') %>
    </h5>
    <%= render "widgets/widgets_grid", widgets: @shared_widgets %>
    <div class="mb-5"></div>
  <% end %>

  <%# Öffentliche Widgets %>
  <% unless @public_widgets.empty? %>
    <h5 class="mb-3">
      <i class="bi bi-globe me-2"></i>
      <%= t('widgets.index.sections.public_widgets') %>
    </h5>
    <%= render "widgets/widgets_grid", widgets: @public_widgets %>
  <% end %>
<% end %>
