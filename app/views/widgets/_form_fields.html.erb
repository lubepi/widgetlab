<% if widget.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <h5 class="alert-heading">
      <%= t('common.errors.prevented_saving', count: widget.errors.count) %>
    </h5>
    <ul class="mb-0">
      <% widget.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="mb-3">
  <%= form.label :name, t('common.labels.name'), class: "form-label" %>
  <%= form.text_field :name, class: "form-control", placeholder: t('widgets.form.name_placeholder'), required: true %>
</div>

<div class="mb-3">
  <%= form.label :description, t('common.labels.description'), class: "form-label" %>
  <%= form.text_area :description, class: "form-control", rows: 3, placeholder: t('widgets.form.description_placeholder') %>
</div>

<div class="mb-3">
  <%= form.label :widget_type, t('activerecord.attributes.widget.widget_type'), class: "form-label" %>
  <%= form.select :widget_type, Widget.widget_types.keys.map { |k| [k.titleize, k] }, { prompt: t('widgets.form.widget_type_prompt') }, { class: "form-select", required: true } %>
  <div class="form-text"><%= t('widgets.form.widget_type_help') %></div>
</div>

<div class="mb-3">
  <%= form.label :color, t('common.labels.color'), class: "form-label" %>
  <%= form.color_field :color, class: "form-control form-control-color", value: widget.color || "#0d6efd", style: "width: 60px; height: 40px;" %>
</div>

<div class="mb-3">
  <%= form.label :unit, t('common.labels.unit'), class: "form-label" %>
  <%= form.text_field :unit, class: "form-control", placeholder: t('widgets.form.unit_placeholder') %>
  <div class="form-text"><%= t('widgets.form.unit_help') %></div>
</div>

<div data-controller="data-source-preview">
  <div class="mb-3">
    <%= label_tag 'widget[data_source_id]', t('widgets.form.data_source'), class: "form-label" %>
    <% current_data_source_id = widget.widget_data_source_transformer&.data_source_id %>
    <%= select_tag 'widget[data_source_id]', 
        options_from_collection_for_select(@data_sources || DataSource.all, :id, :name, current_data_source_id),
        prompt: t('common.prompts.please_select'), 
        class: "form-select",
        required: true,
        data: { 
          data_source_preview_target: "select",
          action: "change->data-source-preview#loadPreview"
        } %>
    <div class="form-text"><%= t('widgets.form.data_source_help') %></div>
  </div>

  <!-- Daten-Transformation -->
  <div class="card mb-3">
    <div class="card-header">
      <%= t('widgets.form.data_transformation_title') %>
    </div>
    <div class="card-body">
      <p class="text-muted small">
        <%= t('widgets.form.data_transformation_help') %>
      </p>

      <div class="mb-3 d-none" data-data-source-preview-target="container">
        <label class="form-label"><%= t('widgets.form.last_response') %></label>
        <div class="border rounded p-2 bg-body-secondary" style="min-height: 150px; height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.875rem; resize: vertical;">
          <pre class="mb-0" data-data-source-preview-target="content"></pre>
        </div>
        <div class="form-text" data-data-source-preview-target="timestamp"></div>
      </div>

      <% current_config = widget.widget_data_source_transformer&.config || {} %>

    <div class="mb-3">
      <%= label_tag 'widget[transformer_config][json_path]', t('widgets.form.json_path'), class: "form-label" %>
      <%= text_field_tag 'widget[transformer_config][json_path]', 
          current_config['json_path'], 
          class: "form-control", 
          placeholder: t('widgets.form.json_path_placeholder') %>
      <div class="form-text">
        <%= t('widgets.form.json_path_help') %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-4">
        <div class="mb-3">
          <%= label_tag 'widget[transformer_config][multiply]', t('widgets.form.multiplier'), class: "form-label" %>
          <%= number_field_tag 'widget[transformer_config][multiply]', 
              current_config['multiply'], 
              class: "form-control", 
              step: 0.01,
              placeholder: t('widgets.form.multiplier_placeholder') %>
          <div class="form-text"><%= t('widgets.form.multiplier_help') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="mb-3">
          <%= label_tag 'widget[transformer_config][add]', t('widgets.form.addition'), class: "form-label" %>
          <%= number_field_tag 'widget[transformer_config][add]', 
              current_config['add'], 
              class: "form-control", 
              step: 0.01,
              placeholder: t('widgets.form.addition_placeholder') %>
          <div class="form-text"><%= t('widgets.form.addition_help') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="mb-3">
          <%= label_tag 'widget[transformer_config][round]', t('widgets.form.decimal_places'), class: "form-label" %>
          <%= number_field_tag 'widget[transformer_config][round]', 
              current_config['round'], 
              class: "form-control", 
              min: 0, 
              max: 10,
              placeholder: t('widgets.form.decimal_places_placeholder') %>
          <div class="form-text"><%= t('widgets.form.decimal_places_help') %></div>
        </div>
      </div>
    </div>

    <div class="mb-3">
      <%= label_tag 'widget[transformer_config][format]', t('widgets.form.format'), class: "form-label" %>
      <%= select_tag 'widget[transformer_config][format]', 
          options_for_select(
            [
              [t('widgets.form.format_auto'), ''],
              [t('widgets.form.format_number'), 'number'],
              [t('widgets.form.format_integer'), 'integer'],
              [t('widgets.form.format_string'), 'string'],
              [t('widgets.form.format_boolean'), 'boolean']
            ], 
            current_config['format']
          ),
          class: "form-select" %>
      <div class="form-text"><%= t('widgets.form.format_help') %></div>
    </div>
  </div>
</div>
</div>

<!-- Zeitbereich-Konfiguration -->
<div class="card mb-3">
  <div class="card-header">
    <%= t('widgets.form.time_range_title') %>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-6">
        <div class="mb-3">
          <%= form.label :time_range_value, t('widgets.form.time_range_value'), class: "form-label" %>
          <%= form.number_field :time_range_value, class: "form-control", value: widget.time_range_value || 24, min: 1 %>
        </div>
      </div>
      <div class="col-md-6">
        <div class="mb-3">
          <%= form.label :time_range_unit, t('widgets.form.time_range_unit'), class: "form-label" %>
          <%= form.select :time_range_unit, 
              Widget::TIME_RANGE_UNITS.map { |u| [I18n.t("time_units.#{u}", default: u), u] }, 
              { selected: widget.time_range_unit || 'hours' }, 
              { class: "form-select" } %>
        </div>
      </div>
    </div>
    <div class="form-text mb-3"><%= t('widgets.form.time_range_help') %></div>

    <div class="row">
      <div class="col-md-4">
        <div class="mb-3">
          <%= form.label :group_by, t('widgets.form.grouping'), class: "form-label" %>
          <%= form.select :group_by, 
              Widget::GROUP_BY_OPTIONS.map { |o| [I18n.t("group_by.#{o}", default: o), o] }, 
              { selected: widget.group_by || 'hour' }, 
              { class: "form-select" } %>
          <div class="form-text"><%= t('widgets.form.grouping_help') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="mb-3">
          <%= form.label :aggregate_function, t('widgets.form.aggregation'), class: "form-label" %>
          <%= form.select :aggregate_function, 
              Widget::AGGREGATE_FUNCTIONS.map { |f| [I18n.t("aggregate.#{f}", default: f), f] }, 
              { selected: widget.aggregate_function || 'avg' }, 
              { class: "form-select" } %>
          <div class="form-text"><%= t('widgets.form.aggregation_help') %></div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="mb-3">
          <%= form.label :data_limit, t('widgets.form.max_data_points'), class: "form-label" %>
          <%= form.number_field :data_limit, class: "form-control", value: widget.data_limit || 100, min: 10, max: 1000 %>
          <div class="form-text"><%= t('widgets.form.max_data_points_help') %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Zugriffsrechte -->
<div class="card mb-3">
  <div class="card-header">
    <%= t('widgets.form.access_rights_title') %>
  </div>
  <div class="card-body">
    <div class="mb-3">
      <div class="form-check">
        <%= form.check_box :is_public, class: "form-check-input", id: "widget_is_public", 
            data: { action: "change->toggle-access-section" } %>
        <%= form.label :is_public, t('widgets.form.public_visible'), class: "form-check-label" %>
      </div>
      <div class="form-text"><%= t('widgets.form.public_visible_help') %></div>
    </div>

    <div class="mb-3" id="access-section">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <label class="form-label mb-0"><%= t('widgets.form.users_and_roles') %></label>
        <div class="small text-muted">
          <span class="badge bg-info me-1"><%= t('widgets.roles.viewer') %></span> <%= t('widgets.roles.viewer_description') %>
          <span class="badge bg-primary mx-1"><%= t('widgets.roles.owner') %></span> <%= t('widgets.roles.owner_description') %>
        </div>
      </div>
      
      <div class="card" data-controller="member-picker" data-action="change->member-picker#updateCount">
        <div class="card-body">
          <div class="row g-2 align-items-center mb-2">
            <div class="col-sm">
              <input type="search" class="form-control" placeholder="<%= t('widgets.form.search_placeholder') %>" data-member-picker-target="query" data-action="input->member-picker#filter">
            </div>
          </div>

          <div class="small text-muted mb-2" data-member-picker-target="count"></div>

          <div class="border rounded p-2" style="max-height: 300px; overflow: auto;">
            <% if defined?(@users) && @users.present? %>
              <% @users.each do |user| %>
                <% current_role = @user_widget_roles[user.id]&.role %>
                <div class="d-flex align-items-center justify-content-between mb-2 p-2 border-bottom" data-member-picker-target="item" data-search="<%= user.email %> <%= user.first_name %> <%= user.last_name %>">
                  <div class="d-flex align-items-center flex-grow-1">
                    <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; flex-shrink: 0;">
                      <i class="bi bi-person text-secondary"></i>
                    </div>
                    <div>
                      <div class="fw-medium"><%= user.first_name %> <%= user.last_name %></div>
                      <small class="text-muted"><%= user.email %></small>
                    </div>
                  </div>
                  <div style="min-width: 150px;">
                    <select name="access[user_roles][<%= user.id %>]" class="form-select form-select-sm" data-member-picker-target="checkbox">
                      <option value=""><%= t('widgets.roles.no_access') %></option>
                      <% @roles.each do |role| %>
                        <option value="<%= role %>" <%= 'selected' if current_role == role %>>
                          <%= t("widgets.roles.#{role}", default: role.capitalize) %>
                        </option>
                      <% end %>
                    </select>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const publicCheckbox = document.getElementById('widget_is_public');
    const accessSection = document.getElementById('access-section');
    
    function toggleAccessSection() {
      if (publicCheckbox && accessSection) {
        const isPublic = publicCheckbox.checked;
        const inputs = accessSection.querySelectorAll('input, select');
        
        inputs.forEach(input => {
          input.disabled = isPublic;
        });
        
        if (isPublic) {
          accessSection.style.opacity = '0.5';
          accessSection.style.pointerEvents = 'none';
        } else {
          accessSection.style.opacity = '1';
          accessSection.style.pointerEvents = 'auto';
        }
      }
    }
    
    if (publicCheckbox) {
      publicCheckbox.addEventListener('change', toggleAccessSection);
      // Initial state
      toggleAccessSection();
    }
  })();
</script>
