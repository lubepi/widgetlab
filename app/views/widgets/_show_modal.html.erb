<%= turbo_frame_tag "widget_modal" do %>
  <div class="modal fade show" id="widgetShowModal" tabindex="-1" aria-labelledby="widgetShowModalLabel" aria-modal="true" role="dialog" style="display: block;" data-controller="modal">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="widgetShowModalLabel"><%= @widget.name %></h5>
          <button type="button" class="btn-close" aria-label="Close"
                  onclick="document.getElementById('widget_modal').innerHTML = '';"></button>
        </div>
      <div class="modal-body">
        <% if @widget.description.present? %>
          <div class="mb-3">
            <p class="text-muted"><%= @widget.description %></p>
          </div>
        <% end %>

        <div class="card">
          <div class="card-body p-0">
            <div style="height: 400px; padding: 1rem;">
              <%= render @widget %>
            </div>
          </div>
        </div>

        <!-- Widget-Informationen -->
        <div class="mt-4">
          <h6 class="mb-3"><%= t('widgets.show.info') %></h6>
          
          <div class="row g-3">
            <!-- Ersteller -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-person-circle text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.creator') %></small>
                  <span><%= @widget.owner.email %></span>
                </div>
              </div>
            </div>

            <!-- Widget-Typ -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-diagram-3 text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('common.labels.type') %></small>
                  <span><%= @widget.widget_type.titleize %></span>
                </div>
              </div>
            </div>

            <!-- Datenquelle -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-database text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.data_source') %></small>
                  <span><%= @widget.widget_data_source_transformer&.data_source&.name || t('common.labels.none') %></span>
                </div>
              </div>
            </div>

            <!-- Sichtbarkeit -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-<%= @widget.is_public? ? 'globe' : 'lock' %> text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.visibility') %></small>
                  <span><%= @widget.is_public? ? t('common.badges.public') : t('common.badges.private') %></span>
                </div>
              </div>
            </div>

            <!-- Einheit -->
            <% if @widget.unit.present? %>
              <div class="col-md-6">
                <div class="d-flex align-items-center gap-2">
                  <i class="bi bi-rulers text-muted"></i>
                  <div>
                    <small class="text-muted d-block"><%= t('common.labels.unit') %></small>
                    <span><%= @widget.unit %></span>
                  </div>
                </div>
              </div>
            <% end %>

            <!-- Farbe -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <div style="width: 24px; height: 24px; border-radius: 4px; background-color: <%= @widget.color || '#0d6efd' %>; border: 1px solid var(--bs-border-color);"></div>
                <div>
                  <small class="text-muted d-block"><%= t('common.labels.color') %></small>
                  <span><%= @widget.color || '#0d6efd' %></span>
                </div>
              </div>
            </div>

            <!-- Zeitbereich -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-clock-history text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.time_range') %></small>
                  <span><%= @widget.time_range_value %> <%= I18n.t("time_units.#{@widget.time_range_unit}", default: @widget.time_range_unit) %></span>
                </div>
              </div>
            </div>

            <!-- Gruppierung -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-bar-chart text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.grouping') %></small>
                  <span><%= I18n.t("group_by.#{@widget.group_by}", default: @widget.group_by) %></span>
                </div>
              </div>
            </div>

            <!-- Aggregation -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-calculator text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.aggregation') %></small>
                  <span><%= I18n.t("aggregate.#{@widget.aggregate_function}", default: @widget.aggregate_function) %></span>
                </div>
              </div>
            </div>

            <!-- Max. Datenpunkte -->
            <div class="col-md-6">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-hash text-muted"></i>
                <div>
                  <small class="text-muted d-block"><%= t('widgets.show.max_data_points') %></small>
                  <span><%= @widget.data_limit %></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Transformation (falls konfiguriert) -->
          <% if @widget.widget_data_source_transformer&.config.present? %>
            <% config = @widget.widget_data_source_transformer.config %>
            <% has_transformation = config['json_path'].present? || config['multiply'].present? || config['add'].present? || config['round'].present? || config['format'].present? %>
            
            <% if has_transformation %>
              <div class="mt-4">
                <h6 class="mb-2"><%= t('widgets.show.transformation') %></h6>
                <div class="bg-body-secondary rounded p-3">
                  <% if config['json_path'].present? %>
                    <div class="mb-2">
                      <small class="text-muted"><%= t('widgets.show.json_path') %></small>
                      <code class="ms-2"><%= config['json_path'] %></code>
                    </div>
                  <% end %>
                  <% if config['multiply'].present? %>
                    <div class="mb-2">
                      <small class="text-muted"><%= t('widgets.show.multiplier') %></small>
                      <span class="ms-2"><%= config['multiply'] %></span>
                    </div>
                  <% end %>
                  <% if config['add'].present? %>
                    <div class="mb-2">
                      <small class="text-muted"><%= t('widgets.show.addition') %></small>
                      <span class="ms-2"><%= config['add'] %></span>
                    </div>
                  <% end %>
                  <% if config['round'].present? %>
                    <div class="mb-2">
                      <small class="text-muted"><%= t('widgets.show.decimals') %></small>
                      <span class="ms-2"><%= config['round'] %></span>
                    </div>
                  <% end %>
                  <% if config['format'].present? %>
                    <div class="mb-2">
                      <small class="text-muted"><%= t('widgets.show.format') %></small>
                      <span class="ms-2"><%= config['format'].titleize %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="modal-footer">
        <%= link_to add_to_dashboard_widget_path(@widget), 
            class: "btn btn-success me-auto",
            data: { turbo_frame: "widget_modal" } do %>
          <i class="bi bi-plus-circle me-1"></i>
          <%= t('widgets.show.add_to_dashboard') %>
        <% end %>
        <% if @widget.can_edit?(current_user) %>
          <%= link_to t('common.buttons.edit'), edit_widget_path(@widget), 
              class: "btn btn-primary",
              data: { turbo_frame: "widget_modal" } %>
        <% end %>
        <button type="button" class="btn btn-secondary"
                onclick="document.getElementById('widget_modal').innerHTML = '';">
          <%= t('common.buttons.close') %>
        </button>
      </div>
    </div>
  </div>
</div>
<% end %>
