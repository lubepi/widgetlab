<% is_new = user_group.new_record? %>

<% if user_group.errors.any? %>
  <div class="alert alert-danger">
    <h5><%= t('common.errors.prevented_saving', count: user_group.errors.count) %></h5>
    <ul class="mb-0">
      <% user_group.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with(model: user_group, id: (is_new ? "new_user_group_form" : "edit_user_group_form_#{user_group.id}"), url: (is_new ? user_groups_path(format: :turbo_stream) : user_group_path(user_group, format: :turbo_stream)), data: { turbo_frame: "_top" }) do |form| %>
  <div class="mb-3">
    <%= form.label :name, t('common.labels.name'), class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: t('user_groups.form.name_placeholder') %>
  </div>

  <div class="mb-3">
    <%= form.label :member_ids, t('user_groups.form.members_label'), class: "form-label" %>
    <% selected_ids = user_group.members.pluck(:id) %>
    <div class="card" data-controller="member-picker" data-action="change->member-picker#updateCount">
      <div class="card-body">
        <div class="row g-2 align-items-center mb-2">
          <div class="col-sm">
            <input type="search" class="form-control" placeholder="<%= t('user_groups.form.search_placeholder') %>" data-member-picker-target="query" data-action="input->member-picker#filter">
          </div>
          <div class="col-sm-auto">
            <button type="button" class="btn btn-outline-secondary" data-action="member-picker#toggleAll" data-member-picker-checked-param="true"><%= t('common.buttons.all') %></button>
            <button type="button" class="btn btn-outline-secondary" data-action="member-picker#toggleAll" data-member-picker-checked-param="false"><%= t('common.buttons.none') %></button>
          </div>
        </div>

        <div class="small text-muted mb-2" data-member-picker-target="count"></div>

        <div class="border rounded p-2" style="max-height: 260px; overflow: auto;">
          <% User.order(:email).each do |user| %>
            <div class="form-check" data-member-picker-target="item" data-search="<%= user.email %>">
              <input class="form-check-input" type="checkbox" value="<%= user.id %>" name="user_group[member_ids][]" id="user_group_member_<%= user.id %>" data-member-picker-target="checkbox" <%= "checked" if selected_ids.include?(user.id) %>>
              <label class="form-check-label" for="user_group_member_<%= user.id %>"><%= user.email %></label>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
