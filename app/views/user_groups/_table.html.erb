<div class="table-responsive">
  <table class="table table-hover">
    <thead>
      <tr>
        <th><%= t('user_groups.table.headers.name') %></th>
        <th><%= t('user_groups.table.headers.members') %></th>
        <th class="text-end"><%= t('user_groups.table.headers.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% if user_groups.any? %>
        <% user_groups.each do |user_group| %>
          <tr>
            <td><strong><%= user_group.name %></strong></td>
            <td><%= user_group.members.count %></td>
            <td class="text-end">
              <div class="btn-group" role="group">
                <%= link_to edit_user_group_path(user_group),
                    class: "btn btn-sm btn-outline-secondary",
                    title: t('user_groups.table.actions.edit'),
                    data: {
                      turbo_frame: "modal",
                      turbo_method: :get
                    } do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        title="<%= t('user_groups.table.actions.delete') %>"
                        data-action="confirm-delete#open"
                        data-delete-url="<%= user_group_path(user_group) %>"
                        data-delete-title="<%= t('user_groups.table.confirm_delete.title') %>"
                        data-delete-message="<%= t('user_groups.table.confirm_delete.message', name: user_group.name) %>">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="3" class="text-center text-muted py-4">
            <%= t('user_groups.table.empty_state') %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
