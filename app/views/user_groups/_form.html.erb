<%= form_with(model: user_group) do |form| %>
  <% if user_group.errors.any? %>
    <div class="alert alert-danger">
      <h5><%= t('common.errors.prevented_saving', count: user_group.errors.count) %></h5>

      <ul class="mb-0">
        <% user_group.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, t('common.labels.name'), class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div>
    <%= form.submit t('common.buttons.save'), class: "btn btn-primary" %>
  </div>
<% end %>
