<%= turbo_frame_tag "widget_modal" do %>
  <div class="modal fade show" id="editWidgetAccessModal" tabindex="-1" style="display: block;" data-controller="modal">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">
            <i class="bi bi-shield-lock me-2"></i>
            <%= t('user_widget_roles.edit.title') %>
          </h5>
        </div>
        <div class="modal-body">
          <%= form_with(url: access_widget_path(@widget), method: :patch, id: "widget_access_form") do %>
            <div class="mb-3">
              <div class="form-text">
                <%= t('user_widget_roles.edit.widget_label') %> <strong><%= @widget.name %></strong>
              </div>
            </div>

            <div class="mb-3">
              <div class="form-check">
                <%= check_box_tag 'widget[is_public]', '1', @widget.is_public, class: "form-check-input" %>
                <%= label_tag 'widget[is_public]', t('user_widget_roles.edit.is_public_label'), class: "form-check-label" %>
              </div>
              <div class="form-text"><%= t('user_widget_roles.edit.is_public_help') %></div>
            </div>

            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="form-label mb-0"><%= t('user_widget_roles.edit.users_label') %></label>
                <div class="small text-muted">
                  <span class="badge bg-info me-1"><%= t('user_widget_roles.edit.viewer_badge') %></span> <%= t('user_widget_roles.edit.viewer_desc') %>
                  <span class="badge bg-primary mx-1"><%= t('user_widget_roles.edit.owner_badge') %></span> <%= t('user_widget_roles.edit.owner_desc') %>
                </div>
              </div>
              
              <div class="card" data-controller="member-picker" data-action="change->member-picker#updateCount">
                <div class="card-body">
                  <div class="row g-2 align-items-center mb-2">
                    <div class="col-sm">
                      <input type="search" class="form-control" placeholder="<%= t('user_widget_roles.edit.search_placeholder') %>" data-member-picker-target="query" data-action="input->member-picker#filter">
                    </div>
                  </div>

                  <div class="small text-muted mb-2" data-member-picker-target="count"></div>

                  <div class="border rounded p-2" style="max-height: 400px; overflow: auto;">
                    <% @users.each do |user| %>
                      <% current_role = @user_widget_roles[user.id]&.role %>
                      <div class="d-flex align-items-center justify-content-between mb-2 p-2 border-bottom" data-member-picker-target="item" data-search="<%= user.email %> <%= user.first_name %> <%= user.last_name %>">
                        <div class="d-flex align-items-center flex-grow-1">
                          <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; flex-shrink: 0;">
                            <i class="bi bi-person text-secondary"></i>
                          </div>
                          <div>
                            <div class="fw-medium"><%= user.first_name %> <%= user.last_name %></div>
                            <small class="text-muted"><%= user.email %></small>
                          </div>
                        </div>
                        <div style="min-width: 150px;">
                          <select name="access[user_roles][<%= user.id %>]" class="form-select form-select-sm" data-member-picker-target="checkbox">
                            <option value=""><%= t('user_widget_roles.edit.no_access') %></option>
                            <% @roles.each do |role| %>
                              <option value="<%= role %>" <%= 'selected' if current_role == role %>>
                                <%= t("widgets.roles.#{role}", default: role.capitalize) %>
                              </option>
                            <% end %>
                          </select>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="modal-footer">
          <%= link_to t('common.buttons.cancel'), edit_widget_path(@widget), class: "btn btn-secondary", data: { turbo_frame: "widget_modal" } %>
          <button type="submit" class="btn btn-primary" form="widget_access_form">
            <i class="bi bi-check-lg me-1"></i>
            <%= t('common.buttons.save') %>
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
