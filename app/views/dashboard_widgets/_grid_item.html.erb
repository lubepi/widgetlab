<%# Grid Item für Gridstack %>
<% max_width = [dashboard_widget.width || 2, dashboard_widget.dashboard.columns || 12].min %>
<% max_height = [dashboard_widget.height || 2, 4].min %>
<div class="grid-stack-item" 
     id="dashboard_widget_<%= dashboard_widget.id %>"
     data-dashboard-widget-id="<%= dashboard_widget.id %>"
     gs-id="<%= dashboard_widget.id %>"
     gs-x="<%= dashboard_widget.position_x || 0 %>" 
     gs-y="<%= dashboard_widget.position_y || 0 %>" 
     gs-w="<%= max_width %>" 
     gs-h="<%= max_height %>"
     gs-min-w="1"
     gs-min-h="1"
     gs-max-w="<%= dashboard_widget.dashboard.columns || 12 %>"
     gs-max-h="4">
  <div class="grid-stack-item-content">
    <div class="card h-100 dashboard-widget-card <%= dashboard_widget.color.present? ? "border-#{dashboard_widget.color}" : '' %>">
      <!-- Widget Content -->
      <div class="card-body widget-content overflow-hidden p-0">
        <!-- Edit Controls (nur im Edit Mode sichtbar, als Overlay) -->
        <div class="widget-edit-controls position-absolute top-0 end-0 m-2" style="display: none; z-index: 10;">
          <button type="button" 
                  class="btn btn-sm btn-danger"
                  data-action="click->dashboard-grid#removeWidget"
                  title="Widget entfernen">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <%= render widget %>
      </div>
    </div>
  </div>
</div>
