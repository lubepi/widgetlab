<div class="table-responsive">
  <table class="table table-hover">
    <thead>
      <tr>
        <th><%= t('data_sources.table.headers.name') %></th>
        <th><%= t('data_sources.table.headers.type') %></th>
        <th><%= t('data_sources.table.headers.creator') %></th>
        <th><%= t('data_sources.table.headers.public') %></th>
        <th><%= t('data_sources.table.headers.status') %></th>
        <th><%= t('data_sources.table.headers.job') %></th>
        <th><%= t('data_sources.table.headers.created_at') %></th>
        <th class="text-end"><%= t('data_sources.table.headers.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% if data_sources.any? %>
        <% data_sources.each do |data_source| %>
          <tr>
            <td><strong><%= data_source.name %></strong></td>
            <td>
              <% if data_source.mqtt? %>
                <span class="badge bg-info"><%= t('data_sources.table.types.mqtt') %></span>
              <% else %>
                <span class="badge bg-success"><%= t('data_sources.table.types.json_api') %></span>
              <% end %>
            </td>
            <td><%= data_source.creator.email %></td>
            <td>
              <% if data_source.is_public == true %>
                <i class="bi bi-check-circle-fill text-success"></i>
                <%= t('common.labels.yes') %>
              <% else %>
                <i class="bi bi-x-circle-fill text-muted"></i>
                <%= t('common.labels.no') %>
              <% end %>
            </td>
            <td>
              <% if data_source.error? %>
                <span class="badge bg-danger" title="<%= data_source.last_error %>"><%= t('data_sources.table.status.error') %></span>
              <% elsif data_source.ok? %>
                <span class="badge bg-success"><%= t('data_sources.table.status.ok') %></span>
              <% else %>
                <span class="badge bg-secondary"><%= t('data_sources.table.status.inactive') %></span>
              <% end %>
            </td>
            <td>
              <% if data_source.job_running? %>
                <span class="badge bg-info"><%= t('data_sources.table.job.running') %></span>
              <% else %>
                <span class="badge bg-secondary"><%= t('data_sources.table.job.stopped') %></span>
              <% end %>
            </td>
            <td><%= l(data_source.created_at, format: :short) %></td>
            <td class="text-end">
              <div class="btn-group" role="group">
                <% if data_source.job_running? %>
                  <button type="button" class="btn btn-sm btn-outline-success" disabled title="<%= t('data_sources.table.actions.start') %>">
                    <i class="bi bi-play"></i>
                  </button>
                <% else %>
                  <%= link_to start_subscription_data_source_path(data_source),
                      class: "btn btn-sm btn-outline-success",
                      title: t('data_sources.table.actions.start'),
                      data: { turbo_method: :post } do %>
                    <i class="bi bi-play"></i>
                  <% end %>
                <% end %>

                <% if !data_source.job_running? %>
                  <button type="button" class="btn btn-sm btn-outline-warning" disabled title="<%= t('data_sources.table.actions.stop') %>">
                    <i class="bi bi-stop"></i>
                  </button>
                <% else %>
                  <%= link_to stop_subscription_data_source_path(data_source),
                      class: "btn btn-sm btn-outline-warning",
                      title: t('data_sources.table.actions.stop'),
                      data: { turbo_method: :post } do %>
                    <i class="bi bi-stop"></i>
                  <% end %>
                <% end %>

                <%= link_to edit_data_source_path(data_source),
                    class: "btn btn-sm btn-outline-secondary",
                    title: t('data_sources.table.actions.edit'),
                    data: {
                      turbo_frame: "modal",
                      turbo_method: :get
                    } do %>
                  <i class="bi bi-pencil"></i>
                <% end %>

                <% if data_source.is_public != true %>
                  <%= link_to whitelist_data_source_path(data_source),
                      class: "btn btn-sm btn-outline-primary",
                      title: t('data_sources.table.actions.whitelist'),
                      data: {
                        turbo_frame: "modal",
                        turbo_method: :get
                      } do %>
                    <i class="bi bi-person-lock"></i>
                  <% end %>
                <% end %>
                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        title="<%= t('data_sources.table.actions.delete') %>"
                        data-action="confirm-delete#open"
                        data-delete-url="<%= data_source_path(data_source) %>"
                        data-delete-title="<%= t('data_sources.table.confirm_delete.title') %>"
                        data-delete-message="<%= t('data_sources.table.confirm_delete.message', name: data_source.name) %>">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="8" class="text-center text-muted py-4">
            <%= t('data_sources.table.empty_state') %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
