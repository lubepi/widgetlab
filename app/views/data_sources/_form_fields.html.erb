<% is_new = data_source.new_record? %>

<% if data_source.errors.any? %>
  <div class="alert alert-danger">
    <h5><%= t('common.errors.prevented_saving', count: data_source.errors.count) %></h5>
    <ul class="mb-0">
      <% data_source.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="mb-3">
  <%= form.label :name, t('common.labels.name'), class: "form-label" %>
  <%= form.text_field :name, class: "form-control", placeholder: t('data_sources.form.name_placeholder') %>
</div>

<div class="mb-3">
  <%= form.label :source_type, t('common.labels.type'), class: "form-label" %>
  <%= form.select :source_type, 
      options_for_select([
        ["JSON API", "json_api"],
        ["MQTT", "mqtt"]
      ], data_source.source_type),
      { prompt: t('data_sources.form.type_prompt') },
      { 
        class: "form-select",
        disabled: !is_new,
        data: { 
          action: "change->data-source-form#typeChanged",
          data_source_form_target: "typeSelect"
        }
      } %>
  <% unless is_new %>
    <div class="form-text"><%= t('data_sources.form.type_disabled_help') %></div>
  <% end %>
</div>

<div class="mb-3 form-check">
  <%= form.check_box :is_public, class: "form-check-input" %>
  <%= form.label :is_public, t('common.badges.public'), class: "form-check-label" %>
  <div class="form-text"><%= t('data_sources.form.is_public_help') %></div>
</div>

<hr class="my-4">

<div data-data-source-form-target="configContainer">
  <% if data_source.source_type.present? %>
    <%= render "config_fields_#{data_source.source_type}", form: form, data_source: data_source %>
  <% else %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle"></i> <%= t('data_sources.form.select_type_info') %>
    </div>
  <% end %>
</div>
