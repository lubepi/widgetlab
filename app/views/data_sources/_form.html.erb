<%= form_with(model: data_source) do |form| %>
  <% if data_source.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(data_source.errors.count, "error") %> prohibited this data_source from being saved:</h2>

      <ul>
        <% data_source.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :creator_id, style: "display: block" %>
    <%= form.text_field :creator_id %>
  </div>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :source_type, style: "display: block" %>
    <%= form.number_field :source_type %>
  </div>

  <div>
    <%= form.label :config, style: "display: block" %>
    <%= form.text_field :config %>
  </div>

  <div>
    <%= form.label :is_public, style: "display: block" %>
    <%= form.checkbox :is_public %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
