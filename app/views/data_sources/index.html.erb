<% content_for :title, t('data_sources.index.title') %>

<div class="container-fluid py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">
      <i class="bi bi-database me-2"></i>
      <%= t('data_sources.index.title') %>
    </h1>
    <div class="d-flex gap-2">
      <%= button_to start_all_subscriptions_data_sources_path,
          method: :post,
          class: "btn btn-outline-primary" do %>
        <i class="bi bi-play-fill"></i> <%= t('data_sources.index.start_all') %>
      <% end %>

      <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newDataSourceModal">
        <i class="bi bi-plus-circle"></i> <%= t('data_sources.index.new_data_source') %>
      </button>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <%= turbo_frame_tag "data_sources_table" do %>
        <%= render "table", data_sources: @data_sources %>
      <% end %>
    </div>
  </div>
</div>

<%= turbo_frame_tag "modal", data: { controller: "modal-frame" } do %>
  <%= render "modal" %>
<% end %>
