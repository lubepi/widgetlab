<%= form_with(model: dashboard) do |form| %>
  <% if dashboard.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(dashboard.errors.count, "error") %> prohibited this dashboard from being saved:</h2>

      <ul>
        <% dashboard.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :columns, style: "display: block" %>
    <%= form.number_field :columns %>
  </div>

  <div>
    <%= form.label :is_public, style: "display: block" %>
    <%= form.checkbox :is_public %>
  </div>

  <div>
    <%= form.label :icon, style: "display: block" %>
    <%= form.text_field :icon %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
