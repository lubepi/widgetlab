<% content_for :title, "Dashboard bearbeiten" %>

<header class="main-header">
  <div class="dashboard-title">
    <div class="dashboard-icon" style="width: 40px; height: 40px; font-size: 1.25rem;">
      <%= @dashboard.icon.present? ? @dashboard.icon : "📊" %>
    </div>
    <h1><%= @dashboard.name || "Dashboard" %> bearbeiten</h1>
  </div>
</header>

<div class="main-body">
  <%= render "form", dashboard: @dashboard %>
</div>
