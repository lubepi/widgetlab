<% content_for :title, @dashboard.name %>
<% content_for :fullscreen, true %>

<%= turbo_frame_tag "modal" %>

<div class="container-fluid py-4" 
     data-controller="dashboard-grid"
     data-dashboard-grid-columns-value="<%= @dashboard.columns || 12 %>"
     data-dashboard-grid-edit-mode-value="false"
     data-dashboard-grid-update-url-value="<%= update_positions_dashboard_dashboard_widgets_path(@dashboard) %>">
  
  <div id="flash-messages"></div>
  
  <!-- Dashboard Header -->
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center mb-4 gap-3">
    <div class="d-flex align-items-center w-100 w-lg-auto">
      <%= link_to dashboards_path, class: "btn btn-outline-secondary btn-sm me-3" do %>
        <i class="bi bi-arrow-left"></i>
      <% end %>
      <div class="d-flex align-items-center flex-grow-1 overflow-hidden">
        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; flex-shrink: 0;">
          <i class="bi bi-<%= @dashboard.icon.presence || 'grid-1x2' %> fs-5 text-primary"></i>
        </div>
        <div class="overflow-hidden">
          <h1 class="mb-0 h3 text-truncate"><%= @dashboard.name %></h1>
          <div class="d-flex gap-2 mt-1 flex-wrap">
            <% if @dashboard.is_public %>
              <span class="badge bg-success"><i class="bi bi-globe me-1 d-none d-sm-inline"></i><%= t('common.badges.public') %></span>
            <% else %>
              <span class="badge bg-secondary"><i class="bi bi-lock me-1 d-none d-sm-inline"></i><%= t('common.badges.private') %></span>
            <% end %>
            <span class="badge bg-info">
              <i class="bi bi-columns-gap me-1 d-none d-sm-inline"></i><%= @dashboard.columns || 12 %> <%= t('common.labels.columns') %>
            </span>
          </div>
        </div>
      </div>
    </div>
  
    <div class="d-flex gap-2 flex-wrap w-100 w-lg-auto justify-content-end">
      <!-- Info Dropdown -->
      <div class="dropdown d-none d-md-block">
        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-info-circle"></i>
        </button>
        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 300px;">
          <h6 class="dropdown-header px-0"><%= t('dashboards.show.info') %></h6>
          <div class="mb-2">
            <small class="text-muted d-block"><%= t('dashboards.show.created') %></small>
            <span><%= @dashboard.created_at.strftime("%d.%m.%Y um %H:%M") %></span>
          </div>
          <div class="mb-2">
            <small class="text-muted d-block"><%= t('dashboards.show.last_edited') %></small>
            <span><%= @dashboard.updated_at.strftime("%d.%m.%Y um %H:%M") %></span>
          </div>
          <div>
            <small class="text-muted d-block"><%= t('dashboards.show.widgets_count') %></small>
            <span><%= @dashboard.widgets.count %> Widget<%= @dashboard.widgets.count == 1 ? '' : 's' %></span>
          </div>
        </div>
      </div>

      <% if @dashboard.can_edit?(current_user) %>
        <!-- Edit/View Mode Toggle Button -->
        <button type="button" 
                class="btn btn-outline-primary flex-shrink-0"
                data-dashboard-grid-target="modeToggle"
                data-action="click->dashboard-grid#toggleMode">
          <i class="bi bi-pencil me-1"></i>
          <span class="d-none d-sm-inline"><%= t('common.buttons.edit') %></span>
        </button>

        <!-- Add Widget Button (nur im Edit Mode sichtbar) -->
        <%= link_to select_widget_dashboard_dashboard_widgets_path(@dashboard), 
                    class: "btn btn-success flex-shrink-0",
                    style: "display: none;",
                    data: { 
                      turbo_frame: "modal",
                      dashboard_grid_target: "addWidgetBtn"
                    } do %>
          <i class="bi bi-plus-lg me-1"></i>
          <span class="d-none d-sm-inline"><%= t('dashboards.show.add_widget') %></span>
        <% end %>
      <% end %>
      
      <% if @dashboard.owner?(current_user) %>
        <%= link_to access_dashboard_path(@dashboard), class: "btn btn-outline-secondary d-none d-lg-inline-flex", data: { turbo_frame: "modal" } do %>
          <i class="bi bi-shield-lock me-1"></i><span class="d-none d-xl-inline"><%= t('dashboards.show.access') %></span>
        <% end %>
        <%= link_to edit_dashboard_path(@dashboard), class: "btn btn-outline-secondary d-none d-md-inline-flex" do %>
          <i class="bi bi-gear me-1"></i><span class="d-none d-xl-inline"><%= t('dashboards.show.settings') %></span>
        <% end %>
        <%= button_to dashboard_path(@dashboard), method: :delete, class: "btn btn-outline-danger d-none d-md-inline-flex",
            data: { turbo_confirm: t('dashboards.show.confirm_delete', name: @dashboard.name) } do %>
          <i class="bi bi-trash"></i>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Widgets Grid -->
  <% if @dashboard.dashboard_widgets.empty? %>
    <div class="card" id="empty-dashboard-state">
      <div class="card-body text-center py-5">
        <i class="bi bi-grid-1x2 display-1 text-muted mb-3"></i>
        <h4 class="text-muted"><%= t('dashboards.show.empty_state.title') %></h4>
        <p class="text-muted mb-4"><%= t('dashboards.show.empty_state.description') %></p>
        <% if @dashboard.can_edit?(current_user) %>
          <button type="button" 
                  class="btn btn-primary"
                  data-action="click->dashboard-grid#toggleMode">
            <i class="bi bi-pencil me-1"></i>
            <%= t('dashboards.show.empty_state.button') %>
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="grid-stack" 
       data-dashboard-grid-target="grid"
       id="dashboard-grid-<%= @dashboard.id %>">
    <% @dashboard.dashboard_widgets.includes(:widget).order(:position_y, :position_x).each do |dashboard_widget| %>
      <%= render "dashboard_widgets/grid_item", dashboard_widget: dashboard_widget, widget: dashboard_widget.widget %>
    <% end %>
  </div>
</div>
