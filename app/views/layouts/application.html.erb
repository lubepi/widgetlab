<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Widgetlab" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Widgetlab">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/gridstack.min.css">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="/chart.umd.js"></script>
    <script src="/gridstack.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="confirm-delete sidebar theme" data-sidebar-default-collapsed-value="<%= current_page?(dashboards_path) %>">
    <%= render "shared/confirm_delete_modal" %>

    <% if content_for?(:fullscreen) %>
      <%# Fullscreen-Modus: Kein Sidebar, volle Breite %>
      <%= turbo_frame_tag "modal" %>
      <div class="container-fluid p-3">
        <% if flash[:notice].present? %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= flash[:notice] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>
        <% if flash[:alert].present? %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= flash[:alert] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% end %>

        <%= yield %>
      </div>
    <% else %>
      <%# Normaler Modus: Mit Sidebar %>
      <div class="container-fluid">
        <div class="row flex-nowrap">
          <aside class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 bg-body-tertiary border-end min-vh-100 sidebar" data-sidebar-target="sidebar">
          <div class="d-flex flex-column align-items-center align-items-sm-start px-3 pt-3 text-body sidebar-inner w-100">
            <%= link_to root_path, class: "d-flex align-items-center pb-3 mb-2 text-decoration-none" do %>
              <span class="fs-5 fw-semibold sidebar-label d-none d-sm-inline"><%= t('layouts.application.title') %></span>
            <% end %>

            <button type="button" class="btn btn-sm btn-outline-secondary mb-2 sidebar-toggle-btn" data-action="sidebar#toggle" aria-label="<%= t('layouts.application.toggle_sidebar') %>">
              <i class="bi" data-sidebar-target="toggleIcon"></i>
            </button>

            <ul class="nav nav-pills flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start w-100" id="menu">
              <li class="nav-item w-100">
                <div class="small text-uppercase text-secondary px-3 mt-2 mb-1 sidebar-section-label"><%= t('layouts.application.navigation.overview') %></div>
              </li>

              <li class="nav-item w-100">
                <%= link_to dashboards_path, class: "nav-link px-3 #{current_page?(dashboards_path) ? 'active' : 'text-body'}" do %>
                  <i class="bi bi-speedometer2 me-2"></i>
                  <span class="d-none d-sm-inline sidebar-label"><%= t('layouts.application.navigation.dashboards') %></span>
                <% end %>
              </li>

              <li class="nav-item w-100">
                <%= link_to widgets_path, class: "nav-link px-3 #{current_page?(widgets_path) ? 'active' : 'text-body'}" do %>
                  <i class="bi bi-grid me-2"></i>
                  <span class="d-none d-sm-inline sidebar-label"><%= t('layouts.application.navigation.widgets') %></span>
                <% end %>
              </li>

              <% if admin? %>
                <li class="nav-item w-100">
                  <hr class="my-3">
                </li>

                <li class="nav-item w-100">
                  <div class="small text-uppercase text-secondary px-3 mt-2 mb-1 sidebar-section-label"><%= t('layouts.application.navigation.admin') %></div>
                </li>

                <li class="nav-item w-100">
                  <%= link_to data_sources_path, class: "nav-link px-3 #{current_page?(data_sources_path) ? 'active' : 'text-body'}" do %>
                    <i class="bi bi-database me-2"></i>
                    <span class="d-none d-sm-inline sidebar-label"><%= t('layouts.application.navigation.data_sources') %></span>
                  <% end %>
                </li>

                <li class="nav-item w-100">
                  <%= link_to user_groups_path, class: "nav-link px-3 #{current_page?(user_groups_path) ? 'active' : 'text-body'}" do %>
                    <i class="bi bi-people me-2"></i>
                    <span class="d-none d-sm-inline sidebar-label"><%= t('layouts.application.navigation.groups') %></span>
                  <% end %>
                </li>

                <li class="nav-item w-100">
                  <%= link_to users_path, class: "nav-link px-3 #{current_page?(users_path) ? 'active' : 'text-body'}" do %>
                    <i class="bi bi-person-badge me-2"></i>
                    <span class="d-none d-sm-inline sidebar-label"><%= t('layouts.application.navigation.users') %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>

            <hr class="w-100">

            <div class="pb-3 w-100">
              <button type="button" class="btn btn-sm btn-outline-secondary w-100 sidebar-theme-btn" data-action="theme#toggle" aria-label="<%= t('layouts.application.toggle_theme') %>">
                <i class="bi" data-theme-target="icon"></i>
                <span class="sidebar-label d-none d-sm-inline ms-2" data-theme-target="label"></span>
              </button>
            </div>

            <%# Sprachumschalter %>
            <div class="pb-3 w-100">
              <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary w-100 dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-globe me-2"></i>
                  <span class="sidebar-label d-none d-sm-inline"><%= I18n.locale == :de ? 'DE' : 'EN' %></span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <%= button_to update_locale_path(locale: :de), method: :patch, class: "dropdown-item #{'active' if I18n.locale == :de}", data: { turbo: false } do %>
                      <i class="bi bi-check2 me-2 <%= 'invisible' unless I18n.locale == :de %>"></i><%= t('layouts.application.language.de') %>
                    <% end %>
                  </li>
                  <li>
                    <%= button_to update_locale_path(locale: :en), method: :patch, class: "dropdown-item #{'active' if I18n.locale == :en}", data: { turbo: false } do %>
                      <i class="bi bi-check2 me-2 <%= 'invisible' unless I18n.locale == :en %>"></i><%= t('layouts.application.language.en') %>
                    <% end %>
                  </li>
                </ul>
              </div>
            </div>

            <div class="pb-3 w-100">
              <% if user_signed_in? %>
                <div class="d-flex align-items-center justify-content-between w-100 px-3 sidebar-footer">
                  <div class="text-truncate me-2 sidebar-footer-label">
                    <div class="fw-semibold"><%= [current_user&.first_name, current_user&.last_name].compact.join(" ") %></div>
                    <div class="small text-secondary"><%= current_user&.email %></div>
                  </div>
                  <%= link_to logout_path, class: "btn btn-sm btn-outline-secondary sidebar-logout-btn", data: { turbo: false } do %>
                    <i class="bi bi-box-arrow-right"></i>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </aside>

        <main class="col py-3">
          <% if flash[:notice].present? %>
            <div class="alert alert-success" role="alert"><%= flash[:notice] %></div>
          <% end %>
          <% if flash[:alert].present? %>
            <div class="alert alert-danger" role="alert"><%= flash[:alert] %></div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>
    <% end %>
  </body>
</html>
